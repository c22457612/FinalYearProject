{
  "manifest_version": 3,
  "name": "Visual Privacy Toolkit",
  "version": "0.1.0",
  "description": "Local extension for Visual Privacy Toolkit capture, site trust flow, and Browser API signals.",
  "action": { "default_popup": "popup.html" },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "notifications",
    "webNavigation",
    "tabs",
    "webRequest",
    "cookies"
  ],
  "host_permissions": [
  "<all_urls>",
  "http://127.0.0.1:4141/*"
  ],
  "background": { "service_worker": "background.js" }
  ,
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["api-gate-shared.js", "api-signal-bridge.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["api-signal-canvas-bootstrap.js", "api-gate-shared.js", "api-signal-canvas-patch.js", "api-signal-main.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
